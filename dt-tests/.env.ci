# CI baseline environment for dt-tests automation.
#
# This file is a curated subset of dt-tests/tests/.env:
# - keep the common envs that docker-compose.integration.yml or current auto scripts can provision reasonably
# - avoid the full local matrix by default; for extended stacks use dt-tests/tests/.env explicitly

# mysql
mysql_extractor_url=mysql://root:123456@127.0.0.1:3307?ssl-mode=disabled
mysql_sinker_url=mysql://root:123456@127.0.0.1:3308?ssl-mode=disabled
mysql_meta_center_url=mysql://root:123456@127.0.0.1:3309?ssl-mode=disabled

# mysql 8.0
mysql_extractor_url_8_0=mysql://root:123456@127.0.0.1:3311?ssl-mode=disabled
mysql_sinker_url_8_0=mysql://root:123456@127.0.0.1:3312?ssl-mode=disabled

# mysql case-sensitive
case_sensitive_mysql_extractor_url=mysql://root:123456@127.0.0.1:3311?ssl-mode=disabled
case_sensitive_mysql_sinker_url=mysql://root:123456@127.0.0.1:3312?ssl-mode=disabled

# mysql cycle nodes
mysql_cycle_node1_url=mysql://root:123456@127.0.0.1:3307?ssl-mode=disabled
mysql_cycle_node2_url=mysql://root:123456@127.0.0.1:3308?ssl-mode=disabled
mysql_cycle_node3_url=mysql://root:123456@127.0.0.1:3309?ssl-mode=disabled

# mysql without auth
