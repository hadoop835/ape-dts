mongo_sinker_url=mongodb://root:123456@127.0.0.1:27016/admin

# mongo without auth
mongo_extractor_without_auth_url=mongodb://127.0.0.1:27017/admin
mongo_extractor_username=root
mongo_extractor_password=123456
mongo_sinker_without_auth_url=mongodb://127.0.0.1:27016/admin
